# ==============================================================================
# NatureWellness Automation Engine — Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.
# ==============================================================================

# Supabase (required)
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_key_here

# Anthropic (required if using AI features)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# USDA FoodData Central — free key at https://fdc.nal.usda.gov/api-guide.html
USDA_API_KEY=your_usda_api_key_here

# External API base URLs — defaults work, only override if needed
OPEN_TARGETS_API_URL=https://api.platform.opentargets.org/api/v4/graphql
REACTOME_API_URL=https://reactome.org/ContentService
CHEMBL_API_URL=https://www.ebi.ac.uk/chembl/api/data
FOODB_API_URL=https://foodb.ca

# App settings
APP_ENV=production
LOG_LEVEL=INFO
CORS_ORIGINS=https://your-frontend-domain.com
